class Solution:
    def maxArea(self, heights: List[int]) -> int:
        left, right = 0, len(heights)-1
        res = []
    
        if len(heights) == 2:
            return min(heights) * 1

        while left < right and right > left:
            if heights[left] >= heights[right]:
                res.append(min(heights[left], heights[right]) * abs(right-left))
                right -= 1
            if heights[right] >= heights[left]:
                res.append(min(heights[left], heights[right]) * abs(left-right))
                left += 1
            # print(heights[left], heights[right], res)

        return max(res)
