class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        res = []
        for n in range(len(nums)):
            res.append(self.multi(nums[:n]) * self.multi(nums[n+1:]))
        return res

    def multi(self, nums):
        res = 1
        for n in nums:
            res *= n
        return res
